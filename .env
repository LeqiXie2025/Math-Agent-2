# 飞书配置 (已配置)
FEISHU_APP_ID=输入您的飞书ID
FEISHU_APP_SECRET=输入您的飞书密钥
FEISHU_VERIFICATION_TOKEN=输入您的飞书确认码
FEISHU_ENCRYPT_KEY=输入您的飞书密钥

# DeepSeek API 配置
DEEPSEEK_API_KEY=输入您的deepseek密钥
APP_PORT=5656
APP_HOST=0.0.0.0
DEBUG=True
SECRET_KEY=dev-secret-key-for-flask-app-2024

# 应用配置
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,pdf,docx,txt

# OCR配置
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# 语言模型配置
MODEL_NAME=deepseek-chat
MAX_TOKENS=4000
TEMPERATURE=0.3

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5
